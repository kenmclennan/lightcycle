#!/usr/bin/env bash
# Provision a fresh checkout to a runnable state: check prerequisites, install the
# dev environment, initialise the lightcycle store, and verify. Idempotent - safe to re-run.
#
# The engine itself runs on system python3 with zero runtime deps; uv/pytest are
# dev-only (for the tests). So `bin/lc` works without the venv; the venv is for
# `bash tests/run.sh`.
set -euo pipefail
cd "$(dirname "${BASH_SOURCE[0]}")/.."

say()  { printf '\n==> %s\n' "$1"; }
need() { command -v "$1" >/dev/null 2>&1 || { echo "missing prerequisite: $1 - $2"; exit 1; }; }

say "Checking prerequisites"
need python3 "install Python >= 3.11"
need uv      "install uv: https://docs.astral.sh/uv/getting-started/installation/"
need git     "install git"
echo "ok: python3, uv, git"

say "Installing the dev environment (uv sync)"
uv sync

say "Initialising the lightcycle store"
./bin/lc init

say "Verifying (fast unit suite)"
uv run pytest tests/unit -q

say "Ready. Run 'bash tests/run.sh' for the full suite, or './bin/lc driver' to start working."
